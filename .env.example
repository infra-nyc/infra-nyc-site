# ── Jobs board ────────────────────────────────────────────────────────────────
# Resend — used to email megan@infra.community on new interest submissions
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# Sender address (must be a verified domain in your Resend account)
RESEND_FROM_EMAIL=jobs@infra.nyc

# Airtable table for jobs interest (optional — uses AIRTABLE_BASE_ID above)
AIRTABLE_JOBS_TABLE_NAME=Jobs Interest

# ── Community application form ─────────────────────────────────────────────────
# Choose one backend. Airtable takes precedence when both are configured.

# Airtable
AIRTABLE_API_KEY=pat_xxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appxxxxxxxxxxxxxx
AIRTABLE_TABLE_NAME=Applications

# Google Sheets via service account
GOOGLE_SERVICE_ACCOUNT_EMAIL=infra-nyc-writer@example.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_SHEET_TAB=Applications
